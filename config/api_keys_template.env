# ==============================================================================
# RPC PROVIDERS (for direct blockchain access)
# ==============================================================================

# ALCHEMY (FREE tier: 300M compute units/month)
# Get key at: https://www.alchemy.com/
ALCHEMY_API_KEY=your_alchemy_api_key_here
ALCHEMY_ETHEREUM_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ALCHEMY_ARBITRUM_URL=https://arb-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ALCHEMY_OPTIMISM_URL=https://opt-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ALCHEMY_BASE_URL=https://base-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# INFURA (FREE tier: 100K requests/day)
# Get key at: https://infura.io/
INFURA_PROJECT_ID=your_infura_project_id_here
INFURA_PROJECT_SECRET=your_infura_secret_here

# QUICKNODE (alternative, various tiers)
# Get key at: https://www.quicknode.com/
QUICKNODE_ENDPOINT=your_quicknode_endpoint_here

# ==============================================================================
# GENERAL CONFIGURATION
# ==============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Data storage settings
DATA_DIR=./data
CACHE_DIR=./cache

# Database (optional, for persistent storage)
DATABASE_URL=sqlite:///data/crypto_statarb.db

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# Rate limiting defaults (requests per minute)
DEFAULT_RATE_LIMIT=60
CEX_RATE_LIMIT=1200
DEX_RATE_LIMIT=100

# ==============================================================================
# SECURITY NOTES
# ==============================================================================
#
# API Key Best Practices:
# ----------------------
# 1. Use separate keys for development and production
# 2. Enable IP whitelisting on all exchanges
# 3. Use read-only permissions for data collection
# 4. Set up 2FA on all exchange accounts
# 5. Regularly rotate API keys (monthly recommended)
# 6. Monitor API key usage for anomalies
# 7. Never share keys in logs, error messages, or screenshots
#
# If you suspect key compromise:
# 1. Immediately disable the compromised key
# 2. Generate new keys
# 3. Review recent API activity for unauthorized access
# 4. Update all systems using the old keys
#
# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
