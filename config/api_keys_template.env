# ==============================================================================
# CRYPTO STATISTICAL ARBITRAGE - API KEYS TEMPLATE
# ==============================================================================
#
# 47 DATA SOURCES SUPPORTED
#
# CRITICAL SECURITY WARNING:
# --------------------------
# 1. NEVER commit actual API keys to version control
# 2. Copy this file to .env and fill in your actual keys
# 3. The .env file is gitignored and should NEVER be committed
# 4. Use read-only API keys where possible (no trading permissions)
# 5. Rotate keys regularly
# 6. Use IP whitelisting when available
#
# Setup Instructions:
# ------------------
# 1. Copy this file: cp api_keys_template.env .env
# 2. Edit .env and replace placeholders with your actual keys
# 3. Ensure .env is in .gitignore (it should be by default)
# 4. Load in Python: from dotenv import load_dotenv; load_dotenv()
#
# FREE vs PAID Sources:
# --------------------
# FREE (no key needed): hyperliquid, dydx, geckoterminal, dexscreener,
#                       vertex, jupiter, cowswap, curve, sushiswap, gmx,
#                       defillama, lyra, dopex
# FREE PUBLIC: binance, bybit, okx, kraken (public endpoints)
# FREE TIER: coingecko, cryptocompare, messari, covalent, flipside
# PAID: glassnode, nansen, arkham, kaiko, santiment, coinmetrics
#
# ==============================================================================

# ==============================================================================
# CENTRALIZED EXCHANGES (CEX) - 6 Sources
# ==============================================================================

# BINANCE (FREE public endpoints, key recommended for higher limits)
# Get keys at: https://www.binance.com/en/my/settings/api-management
# Rate limit: 1200/min public, 6000/min with key
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# BYBIT (FREE public endpoints, key for higher limits)
# Get keys at: https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_SECRET_KEY=your_bybit_secret_key_here

# OKX (FREE public endpoints)
# Get keys at: https://www.okx.com/account/my-api
OKX_API_KEY=your_okx_api_key_here
OKX_SECRET_KEY=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here

# COINBASE (key required)
# Get keys at: https://www.coinbase.com/settings/api
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_PRIVATE_KEY=your_coinbase_private_key_here

# KRAKEN (FREE public endpoints)
# Get keys at: https://www.kraken.com/u/security/api
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_PRIVATE_KEY=your_kraken_private_key_here

# CME (institutional, paid)
# Contact: https://www.cmegroup.com/market-data.html
CME_API_KEY=your_cme_api_key_here

# ==============================================================================
# HYBRID VENUES - 2 Sources (FREE)
# ==============================================================================

# HYPERLIQUID - FREE, no key required
# Documentation: https://hyperliquid.gitbook.io/
# For trading only (optional):
HYPERLIQUID_WALLET_ADDRESS=your_wallet_address_here
HYPERLIQUID_PRIVATE_KEY=your_private_key_here

# DYDX V4 - FREE, no key required for data
# Documentation: https://docs.dydx.exchange/
# For trading only (optional):
DYDX_MNEMONIC=your_dydx_mnemonic_here

# ==============================================================================
# DEX COLLECTORS - 11 Sources
# ==============================================================================

# UNISWAP via THE GRAPH (FREE tier: 100K queries/month)
# Get API key at: https://thegraph.com/studio/apikeys/
THE_GRAPH_API_KEY=your_graph_api_key_here

# GECKOTERMINAL - FREE, no key required
# Documentation: https://www.geckoterminal.com/dex-api

# DEXSCREENER - FREE, no key required
# Documentation: https://docs.dexscreener.com/

# 1INCH (FREE tier available)
# Get key at: https://portal.1inch.dev/
ONEINCH_API_KEY=your_1inch_api_key_here

# 0x (FREE tier available)
# Get key at: https://0x.org/docs/api
ZEROX_API_KEY=your_0x_api_key_here

# GMX - FREE (uses The Graph subgraph)
# No key required

# VERTEX - FREE, no key required
# Documentation: https://vertex-protocol.gitbook.io/

# JUPITER (Solana) - FREE, no key required
# Documentation: https://station.jup.ag/docs/apis

# COWSWAP - FREE, no key required
# Documentation: https://docs.cow.fi/

# CURVE - FREE (uses subgraph)
# No key required

# SUSHISWAP - FREE (uses subgraph)
# No key required

# ==============================================================================
# OPTIONS COLLECTORS - 4 Sources
# ==============================================================================

# DERIBIT (FREE public data, key for higher limits)
# Get keys at: https://www.deribit.com/account/BTC/api
# Testnet: https://test.deribit.com/
DERIBIT_CLIENT_ID=your_deribit_client_id_here
DERIBIT_CLIENT_SECRET=your_deribit_client_secret_here
DERIBIT_TESTNET=false

# AEVO (key required)
# Get keys at: https://app.aevo.xyz/
AEVO_API_KEY=your_aevo_api_key_here
AEVO_API_SECRET=your_aevo_api_secret_here

# LYRA - FREE (uses subgraph)
# No key required

# DOPEX - FREE (uses subgraph)
# No key required

